NODE_ENV=production
HOST=0.0.0.0
PORT=3000
APP_BASE_URL=https://app.triumphbehavioral.com
MFA_ENABLED=false
INACTIVITY_TIMEOUT_MINUTES=45
INACTIVITY_WARNING_MINUTES=40
ABSOLUTE_SESSION_HOURS=12

DATA_STORE=postgres
